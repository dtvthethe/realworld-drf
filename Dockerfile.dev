# ============================================================
# Dockerfile.dev — CHỈ dùng cho DEV
# ============================================================

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    # 🔑 Trỏ pip cài vào /app/.venv thay vì site-packages mặc định
    #    Giống vendor/ của PHP — mount ra host để VSCode đọc được!
    VIRTUAL_ENV=/app/.venv \
    PATH="/app/.venv/bin:$PATH"

WORKDIR /app

# Cài system dependencies cần cho mysqlclient
RUN apt-get update && apt-get install -y \
    default-libmysqlclient-dev \
    gcc \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements TRƯỚC để tận dụng Docker layer cache
# (Docker chỉ re-install khi requirements.txt thay đổi)
COPY requirements.txt ./

# Tạo venv tại /app/.venv rồi cài packages vào đó
RUN python -m venv $VIRTUAL_ENV \
    && pip install --no-cache-dir -r requirements.txt

# KHÔNG COPY code ở đây!
# Code sẽ được mount vào từ volumes trong docker-compose.yml

EXPOSE 8000
